{
  "name": "venvy",
  "version": "1.0.3",
  "description": "Strict environment variable governance for your projects",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/cjs/index.d.ts",
  "bin": {
    "venvy": "dist/cjs/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/cjs/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "scripts": {
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build": "npm run build:cjs && npm run build:esm",
    "dev": "tsc -w",
    "test": "vitest",
    "prepublishOnly": "npm run build && npm test",
    "example": "node ./dist/cjs/cli/index.js"
  },
  "keywords": [
    "env",
    "environment",
    "validation",
    "config",
    "typescript",
    "governance",
    "node"
  ],
  "author": "Elnatan",
  "license": "MIT",
  "dependencies": {
    "commander": "^14.0.3",
    "inquirer": "^13.3.0",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.9",
    "@types/node": "^20.11.20",
    "typescript": "^5.3.3",
    "vitest": "^1.3.1",
    "zod": "^4.3.6"
  }
}
